		<Compile Include="$(PkgPath)/UsrPostgreSQLStatistic/Schemas/UsrStatsCollectType/UsrStatsCollectType.cs" Condition="Exists('$(PkgPath)/UsrPostgreSQLStatistic/Schemas/UsrStatsCollectType/UsrStatsCollectType.cs')" />
