<Project>
	<ItemGroup Condition="'$(PkgPath)' != ''">
		<Compile Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Assemblies/**" />
		<Compile Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Data/**" />
		<Compile Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/SqlScripts/**" />
		<Compile Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Schemas\**" />
		<Compile Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Resources/**" />
		<EmbeddedResource Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Assemblies/**" />
		<EmbeddedResource Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Data/**" />
		<EmbeddedResource Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/SqlScripts/**" />
		<EmbeddedResource Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Schemas/**" />
		<EmbeddedResource Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Resources/**" />
		<None Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Assemblies/**" />
		<None Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Data/**" />
		<None Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/SqlScripts/**" />
		<None Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Schemas/**" />
		<None Remove="$(PkgPath)/UsrPostgreSQLStatisticsArchiver/Resources/**" />
  </ItemGroup>
</Project>